import pya

layout = pya.Layout()
layout.dbu = 0.00025

top_cell = layout.create_cell("Polygon256")


v1_layer = layout.layer(21, 0)
m1_layer = layout.layer(19, 0)
m2_layer = layout.layer(20, 0)

# V1 via: 18nm x 18nm square at (0,0)
v1 = pya.Polygon([pya.Point(0, 0), pya.Point(72, 0), pya.Point(72, 72), pya.Point(0, 72)])
top_cell.shapes(v1_layer).insert(v1)

# M1 metal: provides good enclosure around V1 (28nm x 28nm)
m1 = pya.Polygon([pya.Point(-20, -20), pya.Point(92, -20), pya.Point(92, 92), pya.Point(-20, 92)])
top_cell.shapes(m1_layer).insert(m1)

# M2 metal: 28nm wide (x), 18nm tall (y) - same height as V1
# This satisfies:
# 1. V1.M2.EN.2: 5nm (20dbu) enclosure on left and right (two opposite sides)
# 2. V1.M2.AUX.2: V1 width (y=18nm) exactly matches M2 width in y-direction
m2 = pya.Polygon([pya.Point(-20, 0), pya.Point(92, 0), pya.Point(92, 72), pya.Point(-20, 72)])
top_cell.shapes(m2_layer).insert(m2)

layout.write("../gds/Polygon256_fixed.gds")
